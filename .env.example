# ============================================================
# CAMIULA Frontend — Variables de entorno
# ============================================================
# Copiar este archivo como .env y ajustar valores.
#
# cp .env.example .env

# ─── Backend FastAPI ──────────────────────────────────────────
# URL base del backend. El frontend agrega /api automáticamente.
# Ejemplo local:  http://localhost:8000
# Ejemplo prod:   https://api.camiula.edu.ve
API_URL=http://localhost:8000

# Timeout de requests al backend (ms). Default: 15000
# API_TIMEOUT=15000

# ─── Mock flags ───────────────────────────────────────────────
# Cada módulo tiene su propio flag.
# true  = usa data mock local (default si no se define)
# false = llama al backend real
#
# Migración: cambiar a 'false' uno por uno cuando el backend
# tenga el endpoint listo. Orden sugerido:
#   1. Pacientes + Doctores (base)
#   2. Citas (depende de pacientes y doctores)
#   3. Historias + Schemas (depende de citas)
#   4. Inventario (independiente)

# Core
MOCK_PACIENTES=true
MOCK_DOCTORES=true
MOCK_CITAS=true
MOCK_HISTORIAS=true
MOCK_SCHEMAS=true

# Inventario (granular por sub-módulo)
MOCK_INVENTORY_MEDICATIONS=true
MOCK_INVENTORY_SUPPLIERS=true
MOCK_INVENTORY_PURCHASE_ORDERS=true
MOCK_INVENTORY_BATCHES=true
MOCK_INVENTORY_PRESCRIPTIONS=true
MOCK_INVENTORY_DISPATCHES=true
MOCK_INVENTORY_LIMITS=true
MOCK_INVENTORY_REPORTS=true
